// ═══════════════════════════════════════════════════════════════════════════
// TNLEA App — Firebase Firestore Security Rules
// ── DEPLOY THESE RULES BEFORE HOSTING ON VERCEL ──
//
// HOW TO DEPLOY (one-time setup):
//   1. npm install -g firebase-tools
//   2. firebase login
//   3. firebase use tnlea-a3ea2   (or: firebase init firestore, select existing project)
//   4. firebase deploy --only firestore:rules
//
// RULES SUMMARY:
//   public_choices:
//     - READ:   Everyone (no login needed) — lets all users see the shared list
//     - CREATE: Everyone (no login needed) — lets anyone add to the shared list
//     - DELETE: Only signed-in users — prevents random deletions
//     - UPDATE: Blocked — entries are immutable
// ═══════════════════════════════════════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── public_choices collection ──────────────────────────────────────────
    match /public_choices/{docId} {

      // Anyone can read the shared public list (cross-device sync works)
      allow read: if true;

      // Anyone can add a college to the public list (no login required)
      allow create: if request.resource.data.keys().hasAll(['code', 'branchCode', 'name', 'branchName', 'addedBy', 'createdAt'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0;

      // Only signed-in users can delete entries
      allow delete: if request.auth != null;

      // Allow updates
      allow update: if true;
    }

    // ── user_choices collection ──────────────────────────────────────────
    match /user_choices/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Deny everything else ──────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
